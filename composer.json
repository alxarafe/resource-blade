{
  "name": "alxarafe/resource-blade",
  "description": "Blade adapter for alxarafe/resource-controller. Provides a RendererContract implementation using Laravel's Blade engine for server-side template rendering.",
  "version": "0.1.0",
  "type": "library",
  "license": "GPL-3.0-or-later",
  "keywords": ["blade", "laravel", "renderer", "template", "resource-controller", "alxarafe"],
  "authors": [
    {
      "name": "Rafael San José",
      "email": "rsanjose@alxarafe.com",
      "homepage": "https://alxarafe.es",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2",
    "alxarafe/resource-controller": "^0.1",
    "illuminate/view": "^10.0 || ^11.0 || ^12.0",
    "illuminate/filesystem": "^10.0 || ^11.0 || ^12.0"
  },
  "autoload": {
    "psr-4": {
      "Alxarafe\\ResourceBlade\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Alxarafe\\ResourceBlade\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.10",
    "phpstan/phpstan": "^2.1",
    "vimeo/psalm": "^6.0"
  },
  "minimum-stability": "stable",
  "config": {
    "sort-packages": true
  }
}
